    },
    "DATOCMS_DRAFT_CONTENT_CDA_TOKEN": {
      "type": "datocmsAccessToken",
      "tokenName": "CDA Only (Draft)"
    }
  },
  "livePreviewUrl": "https://sveltekit-demo-eta.vercel.app/"
